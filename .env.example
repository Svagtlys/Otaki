# Suwayomi connection (set by setup wizard)
SUWAYOMI_URL=
SUWAYOMI_USERNAME=
SUWAYOMI_PASSWORD=

# Filesystem paths (set by setup wizard)
SUWAYOMI_DOWNLOAD_PATH=
LIBRARY_PATH=

# Auth — change this in production
SECRET_KEY=dev-secret-key-change-in-production

# Database (optional — defaults to SQLite)
DATABASE_URL=sqlite+aiosqlite:///./otaki.db
