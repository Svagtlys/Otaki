# Suwayomi connection (set by setup wizard)
SUWAYOMI_URL=
SUWAYOMI_USERNAME=
SUWAYOMI_PASSWORD=

# Filesystem paths (set by setup wizard)
# Docker: LIBRARY_PATH and SUWAYOMI_DOWNLOAD_PATH are set automatically by docker-compose.
# Docker: set SUWAYOMI_URL=http://suwayomi:4567 if using the bundled suwayomi service.
# Local dev: set all three below, or configure via the setup wizard.
SUWAYOMI_DOWNLOAD_PATH=
LIBRARY_PATH=

# Poll and relocation defaults (configurable via /api/settings)
DEFAULT_POLL_DAYS=7
CHAPTER_NAMING_FORMAT={title}/{title} - Ch.{chapter}.cbz
RELOCATION_STRATEGY=auto

# Download retry (number of re-enqueue attempts before permanent failure)
MAX_DOWNLOAD_RETRIES=2

# Auth — change this in production
SECRET_KEY=dev-secret-key-change-in-production

# Database (optional — defaults to SQLite)
DATABASE_URL=sqlite+aiosqlite:///./otaki.db
