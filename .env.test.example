# Copy to .env.test and fill in your values — this file is not loaded by the app
SUWAYOMI_URL=https://suwayomi.example.com
SUWAYOMI_USERNAME=admin
SUWAYOMI_PASSWORD=secret

# Optional — integration tests default to pytest tmp_path if omitted
SUWAYOMI_DOWNLOAD_PATH=
LIBRARY_PATH=

# Optional — a manga title known to exist on your Suwayomi instance, used by
# source_selector integration tests. Defaults to "a" if omitted.
TEST_MANGA_TITLE=
